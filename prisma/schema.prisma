generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DISPATCHER
  ADVISOR
  TECH
  MANAGER
  SERVICE_SYNCNOW_ADMIN
}

enum BlockerReason {
  WAITING_ON_CUSTOMER_APPROVAL
  PARTS_BACKORDERED
  WRONG_OR_DEFECTIVE_PART
  WAITING_ON_SUBLET_OR_OUTSIDE_VENDOR
  WAITING_ON_EXTENDED_WARRANTY_AUTHORIZATION
  QUALITY_CONTROL_REVIEW
  RECHECK_OR_COMEBACK_IN_PROGRESS
  TECH_OVERLOADED_TOO_MANY_JOBS_ASSIGNED
  TECH_BEHIND_ON_CURRENT_JOB
  TECH_UNAVAILABLE_OUT_BREAK_END_OF_DAY
  ADVISOR_MUST_CONTACT_CUSTOMER
  WAITING_ON_SPECIAL_ORDER_OR_SPECIALTY_PART
  WAITING_ON_TSB_OR_TECHNICAL_INFORMATION
  OTHER_NOTES_REQUIRED
}

enum ImportStatus {
  PENDING
  SUCCESS
  FAILED
}

enum RepairValue {
  LOW
  MEDIUM
  HIGH
}

enum ActivityType {
  IMPORT_BATCH_CREATED
  IMPORT_ROW_SYNCED
  IMPORT_ROW_SKIPPED
  RO_INACTIVATED
  BLOCKER_UPSERTED
  BLOCKER_CLEARED
  CONTACT_UPDATED
  CONTACT_RESET
  GOTO_CONNECT_SETTINGS_UPDATED
  GOTO_CONNECT_LINE_MAPPING_UPDATED
  GOTO_CONNECT_LINE_MAPPINGS_RERESOLVED
}

enum AlertTrigger {
  OVERDUE
  CONTACT_SLA_BREACHED
  BLOCKED_AGING
  RENTAL_CAR
  HIGH_REPAIR_VALUE
}

enum CallSessionStatus {
  QUEUED
  FAILED
}

enum RecordingProcessingStatus {
  PENDING
  READY
  FAILED
}

enum TranscriptProcessingStatus {
  PENDING
  READY
  FAILED
}

model Organization {
  id                 String               @id @default(cuid())
  name               String
  slug               String               @unique
  active             Boolean              @default(true)
  users              User[]
  importBatches      ImportBatch[]
  repairOrders       RepairOrder[]
  callSessions       CallSession[]
  slaSettings        SlaSettings?
  goToConnectSettings GoToConnectSettings?
  alertRules         AlertRule[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model PlatformIntegrationSettings {
  id                       String   @id @default("default")
  awsRegion                String?
  s3Bucket                 String?
  s3RawRecordingsPrefix    String?
  s3ProcessedCallsPrefix   String?
  openAiApiKey             String?
  openAiTranscriptionModel String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model User {
  id                   String        @id @default(cuid())
  organizationId       String?
  organization         Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  name                 String?
  email                String        @unique
  passwordHash         String
  role                 Role
  asmNumber            Int?
  techNumber           Int?
  gotoConnectExtension String?
  gotoConnectLineId    String?
  active               Boolean       @default(true)
  imports              ImportBatch[]
  blockerEntries       BlockerState[]
  contactEntries       ContactState[]
  contactRecords       ContactRecord[]
  initiatedCallSessions CallSession[]    @relation("CallSessionInitiatedBy")
  activities           ActivityLog[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@unique([organizationId, role, asmNumber])
  @@unique([organizationId, role, techNumber])
  @@index([organizationId, role])
}

model ImportBatch {
  id               String         @id @default(cuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  uploadedById     String
  uploadedBy       User           @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  sourceFileName   String
  sourceRowCount   Int
  importedRowCount Int            @default(0)
  skippedRowCount  Int            @default(0)
  status           ImportStatus   @default(PENDING)
  createdAt        DateTime       @default(now())
  completedAt      DateTime?
  repairOrders     RepairOrder[]
  rowErrors        ImportRowError[]
  activities       ActivityLog[]
}

model ImportRowError {
  id            String      @id @default(cuid())
  importBatchId String
  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  rowNumber     Int
  roNumber      Int?
  reason        String
  rawRowJson    Json
  createdAt     DateTime    @default(now())

  @@index([importBatchId, rowNumber])
}

model RepairOrder {
  id                   String        @id @default(cuid())
  organizationId       String
  organization         Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  roNumber             Int
  repairValue          RepairValue?
  tag                  String?
  model                String
  year                 Int
  customerName         String
  email                String?
  phone                String?
  asmNumber            Int
  advisorName          String?
  techNumber           Int?
  techName             String?
  mode                 String
  mtRaw                String?
  ttRaw                String?
  promisedRaw          String
  promisedAtNormalized DateTime?
  isActive             Boolean       @default(true)
  lastImportBatchId    String?
  lastImportBatch      ImportBatch?  @relation(fields: [lastImportBatchId], references: [id], onDelete: SetNull)
  rawSourceData        Json
  blockerState         BlockerState?
  contactState         ContactState?
  contactRecords       ContactRecord[]
  callSessions         CallSession[]
  activities           ActivityLog[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@unique([organizationId, roNumber])
  @@index([organizationId, isActive])
  @@index([organizationId, asmNumber, isActive])
  @@index([organizationId, mode, isActive])
}

model BlockerState {
  id               String        @id @default(cuid())
  repairOrderId    String        @unique
  repairOrder      RepairOrder   @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  blockerReason    BlockerReason
  foremanNotes     String?
  blockerStartedAt DateTime      @default(now())
  lastUpdatedAt    DateTime      @updatedAt
  techPromisedDate DateTime?
  dispatcherUserId String
  dispatcherUser   User          @relation(fields: [dispatcherUserId], references: [id], onDelete: Restrict)
  isBlocked        Boolean       @default(true)
  createdAt        DateTime      @default(now())
}

model ContactState {
  id            String      @id @default(cuid())
  repairOrderId String      @unique
  repairOrder   RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  contacted     Boolean     @default(false)
  hasRentalCar  Boolean     @default(false)
  contactedAt   DateTime?
  customerNotes String?
  advisorUserId String?
  advisorUser   User?       @relation(fields: [advisorUserId], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ContactRecord {
  id            String      @id @default(cuid())
  repairOrderId String
  repairOrder   RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  contactedAt   DateTime    @default(now())
  customerNotes String?
  advisorUserId String?
  advisorUser   User?       @relation(fields: [advisorUserId], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())

  @@index([repairOrderId, contactedAt])
}

model ActivityLog {
  id            String        @id @default(cuid())
  type          ActivityType
  repairOrderId String?
  repairOrder   RepairOrder?  @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  importBatchId String?
  importBatch   ImportBatch?  @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  message       String
  metadata      Json?
  createdAt     DateTime      @default(now())

  @@index([repairOrderId, createdAt])
  @@index([importBatchId, createdAt])
}

model SlaSettings {
  id                String       @id @default(cuid())
  organizationId    String       @unique
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  blockedAgingHours Int      @default(8)
  contactSlaHours   Int      @default(2)
  dueSoonHours      Int      @default(12)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model GoToConnectSettings {
  id                String       @id @default(cuid())
  organizationId    String       @unique
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accountKey        String?
  enabled           Boolean  @default(false)
  accessToken       String?
  autoAnswer        Boolean  @default(false)
  clientId          String?
  clientSecret      String?
  goToOrganizationId String?
  phoneNumberId     String?
  launchUrlTemplate String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AlertRule {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trigger        AlertTrigger
  name           String
  enabled        Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, trigger])
}

model CallSession {
  id                         String                     @id @default(cuid())
  organizationId             String
  organization               Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  repairOrderId              String
  repairOrder                RepairOrder                @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  initiatedByUserId          String?
  initiatedByUser            User?                      @relation("CallSessionInitiatedBy", fields: [initiatedByUserId], references: [id], onDelete: SetNull)
  asmNumber                  Int
  customerName               String
  customerPhone              String?
  sourceLineId               String?
  sourceExtension            String?
  goToInitiatorId            String?                    @unique
  status                     CallSessionStatus          @default(QUEUED)
  recordingStatus            RecordingProcessingStatus  @default(PENDING)
  transcriptStatus           TranscriptProcessingStatus @default(PENDING)
  storagePrefix              String
  rawRecordingObjectKey      String?
  processedRecordingObjectKey String?
  transcriptJsonObjectKey    String?
  transcriptTextObjectKey    String?
  lastError                  String?
  requestedAt                DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt

  @@index([organizationId, requestedAt])
  @@index([repairOrderId, requestedAt])
}
